# ─── Frontend (apps/web) ──────────────────────────────────────────────────────

# Stellar network: "testnet" or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Contract addresses (from deployment)
NEXT_PUBLIC_FACTORY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ORACLE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_SETTLEMENT_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_TREASURY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Token addresses
NEXT_PUBLIC_USDC_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Backend / Indexer (backend/indexer) ──────────────────────────────────────

# Neon PostgreSQL. Use BOTH urls (copy from the Neon dashboard):
#   DATABASE_URL = pooled endpoint (host has "-pooler"), append pgbouncer=true.
#                  Used at runtime by the indexer + API.
#   DIRECT_URL   = direct endpoint (host WITHOUT "-pooler").
#                  Used only by `prisma migrate`.
# Local alternative: `docker compose up db` then point both at localhost:5432.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
FACTORY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ORACLE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SETTLEMENT_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
POLL_INTERVAL_MS=5000
WS_PORT=4001
LOG_LEVEL=info

# ─── Oracle Worker (backend/workers/oracle) ───────────────────────────────────

# Private key of the oracle signer account (keep secret!)
ORACLE_SIGNER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ORACLE_POLL_INTERVAL_MS=60000
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Price feed API keys
CMC_API_KEY=your_coinmarketcap_api_key_here

# ─── Deployment (scripts/deploy) ─────────────────────────────────────────────

DEPLOYER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Testnet USDC contract (Stellar Asset Contract for USDC)
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
