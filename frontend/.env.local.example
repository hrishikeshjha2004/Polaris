# Frontend environment — copy to .env.local and fill in after deployment

# ─── Network ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ─── Contract Addresses (copy from .env.deployed after running deploy-testnet.sh)
NEXT_PUBLIC_FACTORY_CONTRACT_ID=
NEXT_PUBLIC_ORACLE_CONTRACT_ID=
NEXT_PUBLIC_SETTLEMENT_CONTRACT_ID=
NEXT_PUBLIC_TREASURY_CONTRACT_ID=
NEXT_PUBLIC_USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# ─── Backend API (optional — app works without it via mock data)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4001
