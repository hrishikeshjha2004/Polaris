{
  "name": "polaris",
  "version": "0.1.0",
  "private": true,
  "description": "Polaris — Prediction Odds & Liquidity for Asset, Result & Information Settlement. A fully on-chain prediction market protocol on Stellar/Soroban.",
  "workspaces": [
    "frontend",
    "packages/shared",
    "packages/sdk",
    "packages/db",
    "backend/indexer",
    "backend/api",
    "backend/workers/oracle"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend/indexer\" \"npm run dev --workspace=backend/api\"",
    "dev:web": "npm run dev --workspace=frontend",
    "dev:indexer": "npm run dev --workspace=backend/indexer",
    "dev:api": "npm run dev --workspace=backend/api",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=packages/db",
    "db:push": "npm run push --workspace=packages/db",
    "db:seed": "npm run seed --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build:contracts": "stellar contract build",
    "test:contracts": "cargo test",
    "deploy:testnet": "bash scripts/deploy/deploy-testnet.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
